        "Volume": 1.15
      },
      {
        "VoiceCode": "id_ID_male_default",
        "DisplayName": "Indonesia Male - Default",
        "Gender": "Male",
        "Language": "id-ID",
        "ModelPath": "Storage/PiperVoices/id_ID/male/default.onnx",
        "LengthScale": 1.1,
        "NoiseScale": 0.65,
        "NoiseW": 0.8,
