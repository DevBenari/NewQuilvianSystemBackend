{
  "AppInfo": {
    "Name": "Quilvian System Backend",
    "BackendVersion": "1.8.10",
    "ApiVersion": "v1",
    "Environment": "Default",
    "FrontendMinimumVersion": "1.8.10",
    "FrontendRecommendedVersion": "1.8.10",
    "ReleaseName": "Create Piper Voice Queue Generator",
    "Description": "Update Feature : Create Piper Voice Queue Generator in Server"
  },
  "DataProtection": {
    "KeysPath": "DataProtectionKeys",
    "ApplicationName": "QuilvianSystemBackend"
  },
  "Jwt": {
    "Issuer": "QuilvianSystemBackend",
    "Audience": "QuilvianSystemFrontend",
    "CookieName": "quilvian_access_token",
    "ExpireMinutes": 60,
    "KioskExpireMinutes": 1440
  },
  "AuthCookie": {
    "Secure": true,
    "SameSite": "None",
    "Domain": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "https://dev.quilvian-mmchospital.com",
      "https://sta.quilvian-mmchospital.com",
      "https://quilvian-mmchospital.com"
    ]
  },
  "SeedSuperAdmin": {
    "Enabled": true,
    "Username": "superadmin",
    "Email": "superadmin@admin.com",
    "FullName": "SuperAdmin"
  },
  "SeedDefaultData": {
    "Enabled": true
  },
  "FileStorage": {
    "UploadRootPath": "Storage/uploads",
    "PublicRequestPath": "/uploads",
    "PublicBaseUrl": "https://api-dev.quilvian-mmchospital.com",
    "DefaultUserProfilePhotoPath": "/uploads/default-profile-photos/user.png",
    "DefaultDoctorProfilePhotoPath": "/uploads/default-profile-photos/dokter.png",
    "ProfilePhotoFolderName": "profile-photo",
    "MaxProfilePhotoSizeMb": 2,
    "AllowedProfilePhotoExtensions": [
      ".jpg",
      ".jpeg",
      ".png",
      ".webp"
    ]
  },
  "PatientQrCode": {
    "LogoPath": "Storage/uploads/system-assets/logo-rsmmc.png"
  },
  "LoginGeofence": {
    "Enabled": true,
    "HospitalName": "RSMMC",
    "Latitude": -6.21984502881807,
    "Longitude": 106.83240137757149,
    "AllowedRadiusMeters": 1000,
    "MaxAccuracyMeters": 250,
    "ApplyToSuperAdmin": false
  },
  "SerilogSettings": {
    "ServiceName": "quilvian-backend",
    "MinimumLevel": "Information",
    "MicrosoftMinimumLevel": "Warning",
    "MicrosoftAspNetCoreMinimumLevel": "Warning",
    "SystemMinimumLevel": "Warning",
    "LogDirectory": "Logs",
    "FileNamePattern": "quilvian-backend-.json",
    "RetainedFileCountLimit": 14,
    "EnableRequestLogging": true,
    "SlowRequestThresholdMs": 3000
  },
  "QueueVoice": {
    "Enabled": true,
    "CacheFolder": "Storage/QueueVoiceCache",
    "PiperExecutablePath": "/opt/piper/piper",
    "PiperModelPath": "Storage/PiperVoices/id_ID/default.onnx",
    "FfmpegExecutablePath": "ffmpeg",
    "DefaultVoiceCode": "id_ID_default",
    "Mp3Bitrate": "128k",
    "ProcessTimeoutSeconds": 30
  },
  "Swagger": {
    "Enabled": true,
    "EnableInProduction": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}