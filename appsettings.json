{
  "AppInfo": {
    "Name": "Quilvian System Backend",
    "BackendVersion": "1.2.8",
    "ApiVersion": "v1",
    "Environment": "Default",
    "FrontendMinimumVersion": "1.2.8",
    "FrontendRecommendedVersion": "1.2.8",
    "ReleaseName": "Next Child Workforce",
    "Description": "Update Workforce CompetencyAssesment, ComplianceAlert, DisciplinaryAction, EmployeementContractHistory, Onboarding, Offboarding, PerformanceReview, ScheduleChange, ShiftSwapRequest"
  },
  "DataProtection": {
    "KeysPath": "/app/dataprotection-keys",
    "ApplicationName": "QuilvianSystemBackend"
  },
  "Jwt": {
    "Issuer": "QuilvianSystemBackend",
    "Audience": "QuilvianSystemFrontend",
    "CookieName": "quilvian_access_token"
  },
  "AuthCookie": {
    "Secure": true,
    "SameSite": "None",
    "Domain": ""
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000",
      "http://127.0.0.1:3000",
      "https://dev.quilvian-mmchospital.com",
      "https://sta.quilvian-mmchospital.com",
      "https://quilvian-mmchospital.com"
    ]
  },
  "SeedSuperAdmin": {
    "Enabled": true,
    "Username": "superadmin",
    "Email": "superadmin@admin.com",
    "FullName": "SuperAdmin"
  },
  "SeedDefaultData": {
    "Enabled": true
  },
  "FileStorage": {
    "UploadRootPath": "/app/uploads",
    "PublicRequestPath": "/uploads",

    "DefaultUserProfilePhotoPath": "/uploads/default-profile-photos/user.png",
    "DefaultDoctorProfilePhotoPath": "/uploads/default-profile-photos/dokter.png",

    "ProfilePhotoFolderName": "profile-photo",
    "MaxProfilePhotoSizeMb": 2,
    "AllowedProfilePhotoExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ]
  },
  "LoginGeofence": {
    "Enabled": true,
    "HospitalName": "RSMMC",
    "Latitude": -6.21984502881807,
    "Longitude": 106.83240137757149,
    "AllowedRadiusMeters": 1000,
    "MaxAccuracyMeters": 250,
    "ApplyToSuperAdmin": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}