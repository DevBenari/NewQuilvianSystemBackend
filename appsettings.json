  "LoginGeofence": {
    "Enabled": true,
    "HospitalName": "RSMMC",
    "Latitude": -6.21984502881807,
    "Longitude": 106.83240137757149,
    "AllowedRadiusMeters": 1000,
    "MaxAccuracyMeters": 250,
    "ApplyToSuperAdmin": false
  },
  "SerilogSettings": {
    "ServiceName": "quilvian-backend",
    "MinimumLevel": "Information",
    "MicrosoftMinimumLevel": "Warning",
    "MicrosoftAspNetCoreMinimumLevel": "Warning",
    "SystemMinimumLevel": "Warning",
    "LogDirectory": "Logs",
