{
  "AppInfo": {
    "Name": "Quilvian System Backend",
    "BackendVersion": "1.2.2",
    "ApiVersion": "v1",
    "Environment": "Default",
    "FrontendMinimumVersion": "1.2.2",
    "FrontendRecommendedVersion": "1.2.2",
    "ReleaseName": "Fitur User Login",
    "Description": "Update User Role Akses, Login Absensi, Login Geolocation"
  },
  "Jwt": {
    "Issuer": "QuilvianSystemBackend",
    "Audience": "QuilvianSystemFrontend",
    "CookieName": "quilvian_access_token"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:3000"
    ]
  },
  "SeedSuperAdmin": {
    "Enabled": false,
    "Username": "superadmin",
    "Email": "superadmin@admin.com",
    "FullName": "Super Administrator"
  },
  "SeedDefaultData": {
    "Enabled": true
  },
  "FileStorage": {
    "ProfilePhotoFolder": "default-photo",
    "MaxProfilePhotoSizeMb": 2,
    "AllowedProfilePhotoExtensions": [ ".jpg", ".jpeg", ".png", ".webp" ]
  },
  "AiSettings": {
    "BaseUrl": "https://api.openai.com/v1/chat/completions",
    "Model": "gpt-4.1-mini"
  },
  "LoginGeofence": {
    "Enabled": false,
    "HospitalName": "",
    "AllowedRadiusMeters": 1000,
    "MaxAccuracyMeters": 100,
    "ApplyToSuperAdmin": false
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}